generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PASIEN
  DOKTER
  APOTEKER
  LAB
  BPJS
  MANAJEMEN
}

enum StatusAntrean {
  MENUNGGU
  DIPERIKSA
  SELESAI
}

enum StatusLab {
  MENUNGGU
  SELESAI
}

enum StatusResep {
  MENUNGGU
  DIAMBIL
}

enum StatusTagihan {
  BELUM_DIBAYAR
  LUNAS
}

enum StatusKlaim {
  MENUNGGU
  DISETUJUI
  DITOLAK
}

model User {
  id         Int      @id @default(autoincrement())
  username   String   @unique
  password   String
  role       Role
  createdAt  DateTime @default(now())
  pasien     Pasien?
}

model Pasien {
  id           Int       @id @default(autoincrement())
  userId       Int       @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  namaLengkap  String
  nik          String    @unique
  noBpjs       String?
  dokumenKtp   String?
  dokumenBpjs  String?
  alamat       String?
  antreans     Antrean[]
}

model Antrean {
  id          Int            @id @default(autoincrement())
  pasienId    Int
  pasien      Pasien         @relation(fields: [pasienId], references: [id], onDelete: Cascade)
  tanggal     DateTime       @db.Date
  noAntrean   Int
  status      StatusAntrean  @default(MENUNGGU)
  rekamMedis  RekamMedis?
  tagihan     Tagihan?
}

model RekamMedis {
  id          Int       @id @default(autoincrement())
  antreanId   Int       @unique
  antrean     Antrean   @relation(fields: [antreanId], references: [id], onDelete: Cascade)
  keluhan     String
  diagnosa    String?
  lab         Lab[]
  resep       Resep[]
}

model Lab {
  id            Int         @id @default(autoincrement())
  rekamMedisId  Int
  rekamMedis    RekamMedis  @relation(fields: [rekamMedisId], references: [id], onDelete: Cascade)
  jenisTes      String
  hasilLab      String?
  status        StatusLab   @default(MENUNGGU)
}

model Resep {
  id            Int         @id @default(autoincrement())
  rekamMedisId  Int
  rekamMedis    RekamMedis  @relation(fields: [rekamMedisId], references: [id], onDelete: Cascade)
  rincianObat   String
  status        StatusResep @default(MENUNGGU)
}

model Tagihan {
  id          Int            @id @default(autoincrement())
  antreanId   Int            @unique
  antrean     Antrean        @relation(fields: [antreanId], references: [id], onDelete: Cascade)
  totalBiaya  Decimal        @db.Decimal(15, 2)
  status      StatusTagihan  @default(BELUM_DIBAYAR)
  klaimBpjs   KlaimBpjs[]
}

model KlaimBpjs {
  id          Int          @id @default(autoincrement())
  tagihanId   Int
  tagihan     Tagihan      @relation(fields: [tagihanId], references: [id], onDelete: Cascade)
  status      StatusKlaim  @default(MENUNGGU)
}
